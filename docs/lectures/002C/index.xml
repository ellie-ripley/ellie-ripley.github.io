    <fr:title text="The relation between SK and SKI">The relation between <html:strong>SK</html:strong> and <html:strong>SKI</html:strong></fr:title>
  </fr:frontmatter>
  <fr:mainmatter>
    <html:p>Have a look at the following example proof:</html:p>
    <fr:tree show-metadata="false">
      <fr:frontmatter>
        <fr:authors>
          <fr:author>
            <fr:link href="/lectures/ellieripley/" title="Ellie Ripley" uri="https://negation.rocks/lectures/ellieripley/" display-uri="ellieripley" type="local">Ellie Ripley</fr:link>
