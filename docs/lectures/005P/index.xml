                    <html:table style="border-collapse: collapse;">
    <html:thead><html:tr>
        <html:td class="topedge"><fr:tex display="inline"><![CDATA[A]]></fr:tex></html:td>
        <html:td class="topedge"><fr:tex display="inline"><![CDATA[\neg  A]]></fr:tex></html:td>
    </html:tr></html:thead>
    <html:tbody>
        <html:tr>
