    <fr:title text="Reflexivity">Reflexivity</fr:title>
    <fr:taxon>Definition</fr:taxon>
  </fr:frontmatter>
  <fr:mainmatter>
    <html:p>A logic is <html:strong>reflexive</html:strong> iff it validates all arguments with the form <fr:tex display="inline"><![CDATA[A \;/\; A]]></fr:tex>.</html:p>
  </fr:mainmatter>
